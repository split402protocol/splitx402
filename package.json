{
  "name": "split402",
  "version": "0.1.0",
  "description": "Referral and commission protocol infrastructure for x402-paid APIs and agent tools.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "corepack pnpm -r --if-present build && tsc -p tsconfig.json",
    "typecheck": "corepack pnpm -r --if-present build && tsc --noEmit -p tsconfig.json && corepack pnpm -r --if-present typecheck",
    "lint": "eslint .",
    "test": "vitest run && corepack pnpm -r --if-present test",
    "test:postgres": "corepack pnpm --filter @split402/control-plane test:postgres",
    "test:watch": "vitest",
    "vectors": "corepack pnpm --filter @split402/protocol vectors",
    "vectors:check": "corepack pnpm --filter @split402/protocol vectors:check",
    "phase6:evidence:bundle": "tsx src/phase6-evidence-bundle.ts",
    "phase6:evidence:assemble": "tsx src/phase6-evidence-assemble.ts",
    "phase6:custody:check": "tsx src/phase6-custody-check.ts",
    "phase6:evidence:status": "tsx src/phase6-evidence-status.ts",
    "phase6:emergency-revocation": "tsx src/phase6-emergency-revocation.ts",
    "phase6:image-provenance": "tsx src/phase6-image-provenance.ts",
    "phase6:incident-drill": "tsx src/phase6-incident-drill.ts",
    "phase6:key-custody": "tsx src/phase6-key-custody.ts",
    "phase6:network-policy": "tsx src/phase6-network-policy.ts",
    "phase6:reconciliation-drill": "tsx src/phase6-reconciliation-drill.ts",
    "phase6:rotation-drill": "tsx src/phase6-rotation-drill.ts",
    "phase6:rollback-drill": "tsx src/phase6-rollback-drill.ts",
    "phase6:rpc-failover": "tsx src/phase6-rpc-failover.ts",
    "phase6:signer-smoke": "tsx src/phase6-signer-smoke.ts",
    "phase6:signer-policy": "tsx src/phase6-signer-policy.ts",
    "phase7:staging-proof": "tsx src/phase7-staging-proof.ts",
    "phase7:staging:init": "tsx src/phase7-staging-init.ts",
    "phase7:hosted:preflight": "tsx src/phase7-hosted-preflight.ts",
    "phase7:staging:collect-reads": "tsx src/phase7-staging-collect-reads.ts",
    "phase7:staging:collect-mcp-gateway": "tsx src/phase7-staging-collect-mcp-gateway.ts",
    "phase7:staging:derive-receipt-verification": "tsx src/phase7-staging-derive-receipt-verification.ts",
    "phase7:staging:assemble": "tsx src/phase7-staging-assemble.ts",
    "phase7:staging:manifest": "tsx src/phase7-staging-manifest.ts",
    "phase7:staging:status": "tsx src/phase7-staging-status.ts",
    "audit": "corepack pnpm audit --audit-level high",
    "control-plane:migrate": "corepack pnpm --filter @split402/control-plane migrate",
    "control-plane": "corepack pnpm --filter @split402/control-plane server",
    "dashboard": "corepack pnpm --filter @split402/dashboard dev",
    "demo:merchant": "corepack pnpm --filter @split402/demo-merchant dev",
    "demo:inspect-offer": "corepack pnpm --filter @split402/demo-agent inspect-offer",
    "demo:setup-buyer": "corepack pnpm --filter @split402/demo-agent setup-buyer",
    "demo:setup-mint": "corepack pnpm --filter @split402/demo-agent setup-mint",
    "demo:setup-existing-token": "corepack pnpm --filter @split402/demo-agent setup-existing-token",
    "demo:preflight": "corepack pnpm --filter @split402/demo-agent preflight",
    "demo:paid-suite": "corepack pnpm build && corepack pnpm --filter @split402/demo-agent paid-suite",
    "demo:agent": "corepack pnpm --filter @split402/demo-agent dev",
    "demo:mcp-bundle": "corepack pnpm --filter @split402/mcp-demo bundle",
    "demo:mcp-gateway": "corepack pnpm --filter @split402/mcp-demo gateway",
    "demo:mcp-gateway:smoke": "corepack pnpm --filter @split402/mcp-demo gateway:smoke",
    "worker:chain": "corepack pnpm --filter @split402/control-plane worker:chain",
    "worker:webhook": "corepack pnpm --filter @split402/control-plane worker:webhook",
    "payout:finality:failover-drill": "corepack pnpm --filter @split402/control-plane payout:finality:failover-drill",
    "signer:payout": "corepack pnpm --filter @split402/payout-signer dev",
    "signer:payout:smoke": "corepack pnpm --filter @split402/payout-signer smoke"
  },
  "dependencies": {
    "@x402/core": "2.16.0",
    "@x402/evm": "2.16.0",
    "@x402/express": "2.16.0",
    "@x402/extensions": "2.16.0",
    "dotenv": "16.4.7",
    "express": "5.2.1",
    "pino": "9.6.0",
    "pino-http": "10.4.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/express": "5.0.6",
    "@types/node": "22.20.0",
    "@types/supertest": "6.0.3",
    "eslint": "9.39.4",
    "globals": "15.14.0",
    "supertest": "7.2.2",
    "tsx": "4.22.4",
    "typescript": "5.7.3",
    "typescript-eslint": "8.62.0",
    "vitest": "4.1.9"
  },
  "pnpm": {
    "overrides": {
      "ws": "8.21.0"
    }
  }
}
