NODE_ENV=development
PORT=4021
LOG_LEVEL=info

# Use "mock" for local route testing without a signed x402 payment.
# Use "x402" when connecting to the real facilitator flow.
SPLIT402_PAYMENT_MODE=mock

SPLIT402_NETWORK=eip155:84532
SPLIT402_ASSET=USDC
SPLIT402_PRICE_USD=0.001
SPLIT402_PAY_TO=0x0000000000000000000000000000000000000000
SPLIT402_FACILITATOR_URL=https://x402.org/facilitator
SPLIT402_SYNC_FACILITATOR=true
SPLIT402_RESOURCE_BASE_URL=http://localhost:4021

# Phase 1 file-backed settlement log.
SPLIT402_DATA_DIR=.data

# Phase 3 Solana Devnet demo merchant/agent settings.
SPLIT402_MERCHANT_ORIGIN=http://localhost:4021
SPLIT402_SERVICE_SEED_HEX=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f
SPLIT402_MERCHANT_PAY_TO=
SPLIT402_REQUIRED_AMOUNT_ATOMIC=10000
SPLIT402_COMMISSION_BPS=2000
SPLIT402_SOLANA_RPC_URL=https://api.devnet.solana.com
SPLIT402_SOLANA_RPC_WS_URL=wss://api.devnet.solana.com
SPLIT402_USE_INVALID_CLAIM=false

# Set with `corepack pnpm demo:setup-buyer` or a funded disposable Devnet key.
SVM_PRIVATE_KEY=
