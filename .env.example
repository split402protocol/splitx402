NODE_ENV=development
PORT=4021
LOG_LEVEL=info

# Use "mock" for local route testing without a signed x402 payment.
# Use "x402" when connecting to the real facilitator flow.
SPLIT402_PAYMENT_MODE=mock

SPLIT402_NETWORK=eip155:84532
SPLIT402_ASSET=USDC
SPLIT402_PRICE_USD=0.001
SPLIT402_PAY_TO=0x0000000000000000000000000000000000000000
SPLIT402_FACILITATOR_URL=https://x402.org/facilitator
SPLIT402_SYNC_FACILITATOR=true
SPLIT402_RESOURCE_BASE_URL=http://localhost:4021

# Phase 1 file-backed settlement log.
SPLIT402_DATA_DIR=.data

# Phase 3 Solana Devnet demo merchant/agent settings.
SPLIT402_MERCHANT_ORIGIN=http://localhost:4021
SPLIT402_SERVICE_SEED_HEX=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f
SPLIT402_MERCHANT_PAY_TO=
SPLIT402_REQUIRED_AMOUNT_ATOMIC=10000
SPLIT402_COMMISSION_BPS=2000
SPLIT402_SOLANA_RPC_URL=https://api.devnet.solana.com
SPLIT402_SOLANA_RPC_WS_URL=wss://api.devnet.solana.com
SPLIT402_USE_INVALID_CLAIM=false
SPLIT402_USE_BUYER_AS_DEMO_FEE_PAYER=false
SPLIT402_DEMO_FEE_PAYER_PRIVATE_KEY=

# Set with `corepack pnpm demo:setup-buyer` or a funded disposable Devnet key.
SVM_PRIVATE_KEY=

# Phase 4 durable control-plane runtime settings.
SPLIT402_DATABASE_URL=postgresql://split402:split402@localhost:5432/split402
SPLIT402_DATABASE_POOL_MAX=10
SPLIT402_DATABASE_SSL=false
SPLIT402_CONTROL_PLANE_AUTH_POLICY=required
SPLIT402_CONTROL_PLANE_JSON_LIMIT=256kb
SPLIT402_WALLET_AUTH_CHALLENGE_TTL_MS=300000
SPLIT402_WALLET_AUTH_SESSION_TTL_MS=900000
SPLIT402_WALLET_AUTH_REFRESH_TOKEN_TTL_MS=2592000000

# Phase 7 dashboard settings.
SPLIT402_DASHBOARD_CONTROL_PLANE_URL=http://localhost:4021
SPLIT402_DASHBOARD_PORT=4027
SPLIT402_DASHBOARD_MERCHANT_ID=
SPLIT402_DASHBOARD_REFERRER_WALLET=
SPLIT402_DASHBOARD_CONTROL_PLANE_TOKEN=

# Optional Phase 7 live funding-balance provider for merchant obligations.
# Use solana-rpc to let payout-obligation views report covered/deficit.
SPLIT402_FUNDING_BALANCE_PROVIDER=
SPLIT402_FUNDING_BALANCE_SOLANA_RPC_URL=
SPLIT402_FUNDING_BALANCE_SOLANA_RPC_URLS=
SPLIT402_FUNDING_BALANCE_TOKEN_PROGRAM_ID=

# Phase 7 staging proof fields.
SPLIT402_PHASE7_PROOF_ID=
SPLIT402_PHASE7_PROOF_DATE=
SPLIT402_PHASE7_PROOF_REVIEWERS=
SPLIT402_PHASE7_SOURCE_COMMIT=
SPLIT402_PHASE7_STAGING_ENVIRONMENT=
SPLIT402_PHASE7_CONTROL_PLANE_URL=
SPLIT402_PHASE7_DASHBOARD_URL=
SPLIT402_PHASE7_DEMO_MERCHANT_URL=
SPLIT402_PHASE7_WEBHOOK_RECEIVER_URL=
SPLIT402_PHASE7_AGENT_DISCOVERY_EVIDENCE=
SPLIT402_PHASE7_PAID_REQUEST_EVIDENCE=
SPLIT402_PHASE7_RECEIPT_VERIFICATION_EVIDENCE=
SPLIT402_PHASE7_REFERRER_BALANCE_EVIDENCE=
SPLIT402_PHASE7_DASHBOARD_SUMMARY_EVIDENCE=
SPLIT402_PHASE7_WEBHOOK_DELIVERY_EVIDENCE=
SPLIT402_PHASE7_PAYOUT_OBLIGATION_EVIDENCE=
SPLIT402_PHASE7_FUNDING_BALANCE_EVIDENCE=
SPLIT402_PHASE7_MCP_BUNDLE_EVIDENCE=
SPLIT402_PHASE7_COMMANDS_RUN=
SPLIT402_PHASE7_APPROVAL_DECISION=no-go
SPLIT402_PHASE7_APPROVAL_NOTES=
SPLIT402_PHASE7_STAGING_PROOF=

# Phase 4 chain-verification worker settings.
SPLIT402_CHAIN_WORKER_NETWORK=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1
SPLIT402_CHAIN_WORKER_SOLANA_RPC_URL=https://api.devnet.solana.com
# Optional comma-separated failover list. Takes precedence over the single URL.
SPLIT402_CHAIN_WORKER_SOLANA_RPC_URLS=
SPLIT402_CHAIN_WORKER_COMMITMENT=confirmed
SPLIT402_CHAIN_WORKER_RETRY_DELAY_MS=60000
SPLIT402_CHAIN_WORKER_POLL_INTERVAL_MS=5000
SPLIT402_CHAIN_WORKER_ERROR_DELAY_MS=5000
SPLIT402_CHAIN_WORKER_MAX_ITERATIONS=
SPLIT402_CHAIN_WORKER_STOP_ON_ERROR=false

# Phase 4 webhook dispatch worker settings.
SPLIT402_WEBHOOK_WORKER_URL=https://merchant.example/webhooks/split402
SPLIT402_WEBHOOK_WORKER_SECRET=replace-with-a-shared-secret
SPLIT402_WEBHOOK_WORKER_RETRY_DELAY_MS=60000
SPLIT402_WEBHOOK_WORKER_POLL_INTERVAL_MS=5000
SPLIT402_WEBHOOK_WORKER_ERROR_DELAY_MS=5000
SPLIT402_WEBHOOK_WORKER_MAX_ITERATIONS=
SPLIT402_WEBHOOK_WORKER_MAX_ATTEMPTS=10
SPLIT402_WEBHOOK_WORKER_TIMEOUT_MS=5000
SPLIT402_WEBHOOK_WORKER_STOP_ON_ERROR=false

# Phase 6 local-dev payout signer settings.
# Use only disposable Devnet keys here. Production signer isolation is separate
# hardening work.
SPLIT402_PAYOUT_SIGNER_REF=local-dev:payout-key
SPLIT402_PAYOUT_SIGNER_EXPECTED_ADDRESS=
SPLIT402_PAYOUT_SIGNER_SECRET_KEY_JSON=
SPLIT402_PAYOUT_SIGNER_SECRET_KEY_BASE64=
SPLIT402_PAYOUT_SIGNER_PRIVATE_KEY_BASE64=

# Phase 6 remote payout signer settings.
# The control plane sends policy-checked transactions to this isolated signer.
SPLIT402_REMOTE_PAYOUT_SIGNER_REF=kms:split402-devnet-payout
SPLIT402_REMOTE_PAYOUT_SIGNER_URL=
SPLIT402_REMOTE_PAYOUT_SIGNER_KEY_ID=
SPLIT402_REMOTE_PAYOUT_SIGNER_SHARED_SECRET=
SPLIT402_REMOTE_PAYOUT_SIGNER_TIMEOUT_MS=5000

# Phase 6 payout signer appliance settings.
SPLIT402_PAYOUT_SIGNER_SERVICE_PORT=4022
SPLIT402_PAYOUT_SIGNER_SERVICE_REF=kms:split402-devnet-payout
SPLIT402_PAYOUT_SIGNER_SERVICE_NETWORK=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1
SPLIT402_PAYOUT_SIGNER_SERVICE_EXPECTED_FUNDING_WALLET=
SPLIT402_PAYOUT_SIGNER_SERVICE_SHARED_SECRET=
SPLIT402_PAYOUT_SIGNER_SERVICE_SHARED_SECRET_KEY_ID=default
SPLIT402_PAYOUT_SIGNER_SERVICE_AUTH_KEYS_JSON=
SPLIT402_PAYOUT_SIGNER_SERVICE_PRIVATE_KEY_BASE64=
SPLIT402_PAYOUT_SIGNER_SERVICE_SECRET_KEY_BASE64=
SPLIT402_PAYOUT_SIGNER_SERVICE_SECRET_KEY_JSON=

# Phase 6 payout finality reconciliation settings.
# URL settings fall back to the chain-worker Solana RPC config when omitted.
SPLIT402_PAYOUT_FINALITY_NETWORK=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1
SPLIT402_PAYOUT_FINALITY_SOLANA_RPC_URL=https://api.devnet.solana.com
SPLIT402_PAYOUT_FINALITY_SOLANA_RPC_URLS=
SPLIT402_PAYOUT_FINALITY_RETRY_DELAY_MS=30000
SPLIT402_PAYOUT_FINALITY_UNKNOWN_OUTCOME_AFTER_MS=300000
