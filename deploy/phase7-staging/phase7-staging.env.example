# Copy this file to phase7-staging.env before running:
# docker compose -f deploy/phase7-staging/compose.yaml up

NODE_ENV=development
LOG_LEVEL=info

# Host port overrides for the compose stack.
SPLIT402_PHASE7_POSTGRES_PORT=5432
SPLIT402_PHASE7_CONTROL_PLANE_PORT=4021
SPLIT402_PHASE7_DASHBOARD_PORT=4027
SPLIT402_PHASE7_DEMO_MERCHANT_PORT=4023

# Dashboard defaults and hosted-staging viewer gate.
SPLIT402_DASHBOARD_MERCHANT_ID=
SPLIT402_DASHBOARD_REFERRER_WALLET=
SPLIT402_DASHBOARD_CONTROL_PLANE_TOKEN=
SPLIT402_DASHBOARD_VIEWER_TOKEN=replace-with-staging-viewer-token
SPLIT402_DASHBOARD_SESSION_COOKIE_NAME=split402_dashboard_session
SPLIT402_DASHBOARD_SESSION_COOKIE_SECURE=false

# Control-plane funding visibility for Phase 7 payout-obligation evidence.
SPLIT402_FUNDING_BALANCE_PROVIDER=
SPLIT402_FUNDING_BALANCE_SOLANA_RPC_URL=https://api.devnet.solana.com
SPLIT402_FUNDING_BALANCE_SOLANA_RPC_URLS=
SPLIT402_FUNDING_BALANCE_TOKEN_PROGRAM_ID=

# Chain worker settings for Devnet staging.
SPLIT402_CHAIN_WORKER_NETWORK=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1
SPLIT402_CHAIN_WORKER_SOLANA_RPC_URL=https://api.devnet.solana.com
SPLIT402_CHAIN_WORKER_SOLANA_RPC_URLS=
SPLIT402_CHAIN_WORKER_COMMITMENT=confirmed
SPLIT402_CHAIN_WORKER_RETRY_DELAY_MS=60000
SPLIT402_CHAIN_WORKER_POLL_INTERVAL_MS=5000
SPLIT402_CHAIN_WORKER_ERROR_DELAY_MS=5000
SPLIT402_CHAIN_WORKER_STOP_ON_ERROR=false

# Webhook worker settings for hosted staging evidence.
SPLIT402_WEBHOOK_WORKER_URL=
SPLIT402_WEBHOOK_WORKER_SECRET=replace-with-staging-webhook-secret
SPLIT402_WEBHOOK_WORKER_RETRY_DELAY_MS=60000
SPLIT402_WEBHOOK_WORKER_POLL_INTERVAL_MS=5000
SPLIT402_WEBHOOK_WORKER_ERROR_DELAY_MS=5000
SPLIT402_WEBHOOK_WORKER_MAX_ATTEMPTS=10
SPLIT402_WEBHOOK_WORKER_TIMEOUT_MS=5000
SPLIT402_WEBHOOK_WORKER_STOP_ON_ERROR=false

# Demo merchant settings. Fill these before enabling the demo profile.
SPLIT402_PAYMENT_MODE=x402
SPLIT402_NETWORK=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1
SPLIT402_SOLANA_RPC_URL=https://api.devnet.solana.com
SPLIT402_SOLANA_RPC_WS_URL=wss://api.devnet.solana.com
SPLIT402_MERCHANT_PAY_TO=
SPLIT402_REQUIRED_AMOUNT_ATOMIC=10000
SPLIT402_COMMISSION_BPS=1000
SPLIT402_SERVICE_SEED_HEX=
SPLIT402_DEMO_FEE_PAYER_PRIVATE_KEY=
SVM_PRIVATE_KEY=
