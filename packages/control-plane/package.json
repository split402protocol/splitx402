{
  "name": "@split402/control-plane",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "split402-control-plane": "./dist/server.js",
    "split402-control-plane-migrate": "./dist/migrate.js",
    "split402-chain-worker": "./dist/chain-worker.js",
    "split402-webhook-worker": "./dist/webhook-worker.js"
  },
  "files": ["dist", "migrations"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "phase7:staging:seed": "tsx src/phase7-staging-seed.ts",
    "payout:finality:failover-drill": "tsx src/payout-finality-failover-drill.ts",
    "migrate": "tsx src/migrate.ts",
    "test": "vitest run",
    "test:postgres": "node -e \"if (!process.env.SPLIT402_TEST_DATABASE_URL) { console.error('Set SPLIT402_TEST_DATABASE_URL to run live PostgreSQL tests.'); process.exit(1); }\" && vitest run test/postgres-live.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "server": "tsx src/server.ts",
    "worker:chain": "tsx src/chain-worker.ts",
    "worker:webhook": "tsx src/webhook-worker.ts"
  },
  "dependencies": {
    "@solana-program/token": "^0.9.0",
    "@solana/kit": "^5.1.0",
    "@split402/protocol": "workspace:*",
    "express": "5.2.1",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/pg": "8.20.0",
    "@types/supertest": "6.0.3",
    "supertest": "7.2.2",
    "vitest": "^4.1.9"
  }
}
